<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2">

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"/>

    <LinearLayout
        android:id="@+id/topDangerPrompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E6D32F2F"
        android:orientation="horizontal"
        android:padding="16dp"
        android:visibility="gone"
        android:elevation="10dp"
        android:layout_marginTop="100dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚠️ " android:textSize="24sp"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NIGHT ALERT: DANGEROUS PATH" android:textColor="#FFFFFF" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Aap ek unsafe area se travel kr rhe ho!" android:textColor="#F1F3F4" android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="25dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬅️"
                android:textSize="20sp"
                android:paddingEnd="10dp"
                android:clickable="true"/>

            <AutoCompleteTextView
                android:id="@+id/etSearchDestination"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Where to? (e.g., WTP, SKIT)"
                android:textSize="16sp"
                android:textColor="#202124"
                android:singleLine="true"
                android:completionThreshold="1"
                android:dropDownWidth="match_parent"/>

            <TextView
                android:id="@+id/btnSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="20sp"
                android:clickable="true"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnReportArea"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|center_vertical"
        android:layout_marginStart="16dp"
        android:src="@android:drawable/ic_menu_edit"
        app:backgroundTint="#FFFFFF"
        app:tint="#1A73E8"
        app:fabSize="normal" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="16dp"
        android:elevation="5dp">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnMyLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:src="@android:drawable/ic_menu_mylocation"
            app:backgroundTint="#FFFFFF"
            app:tint="#1A73E8"
            app:fabSize="mini"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnFilterRed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:src="@android:drawable/presence_busy"
            app:backgroundTint="#FFFFFF"
            app:tint="#D32F2F"
            app:fabSize="mini"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnFilterYellow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:src="@android:drawable/presence_away"
            app:backgroundTint="#FFFFFF"
            app:tint="#FBC02D"
            app:fabSize="mini"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnFilterGreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/presence_online"
            app:backgroundTint="#FFFFFF"
            app:tint="#00E676"
            app:fabSize="mini"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="0dp"
        android:background="@drawable/bg_bottom_sheet"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <View android:layout_width="40dp" android:layout_height="4dp" android:background="#DADDDF" android:layout_gravity="center_horizontal" android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvRouteTimeDist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculating..."
                android:textColor="#1A73E8"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvRouteType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Safest Route via Safe Zones"
                android:textColor="#5F6368"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

            <Button
                android:id="@+id/btnStartNav"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#1A73E8"
                android:text="Start Safe Navigation"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:cornerRadius="25dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>